# =============================================================================
# LOGISTICS CRM - Environment Configuration Template
# Copy this file to .env and adjust values for your environment
# =============================================================================

# Application
APP_ENV=dev
APP_SECRET=change_me_in_production_32char_secret

# PostgreSQL
POSTGRES_VERSION=16
POSTGRES_DB=logistics_crm
POSTGRES_USER=app
POSTGRES_PASSWORD=secret
DATABASE_URL="postgresql://app:secret@database:5432/logistics_crm?serverVersion=16&charset=utf8"

# Redis
REDIS_URL=redis://redis:6379

# Mailer (Mailpit)
MAILER_DSN=smtp://mailpit:1025

# Messenger
MESSENGER_TRANSPORT_DSN=redis://redis:6379/messages

# JWT / Security
JWT_SECRET=change_me_in_production

# Frontend
VITE_API_BASE_URL=http://localhost:8080/api

# Ports (host:container)
NGINX_PORT=8080
POSTGRES_PORT=5432
REDIS_PORT=6379
MAILPIT_SMTP_PORT=1025
MAILPIT_WEB_PORT=8025
